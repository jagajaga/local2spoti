# Spotify Developer app client ID (free; create at https://developer.spotify.com/dashboard).
# Redirect URI on the app must be http://127.0.0.1:<LOCAL2SPOTI_PORT>/callback
LOCAL2SPOTI_SPOTIFY_CLIENT_ID=

# AcoustID API key (free; https://acoustid.org/api-key).
# Without this, fingerprint matching is disabled.
LOCAL2SPOTI_ACOUSTID_API_KEY=

# Bind port for the local web UI.
LOCAL2SPOTI_PORT=8000

# Optional: Anthropic API key for the AI-rescue stage.
# Used to identify tracks AcoustID couldn't fingerprint (filename-only metadata).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
